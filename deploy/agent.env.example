# /etc/ladder-agent/agent.env
LADDER_LISTEN=0.0.0.0:50051
LADDER_TOKEN=change-me-to-a-long-secret
LADDER_DATA_DIR=/var/lib/ladder-agent

# TLS（install-agent.sh 默认 LADDER_TLS=1 时自动写入）
# Panel 节点登记时把 /etc/ladder-agent/tls/ca.crt 全文贴到 ca_cert_pem
LADDER_TLS_CERT=/etc/ladder-agent/tls/server.crt
LADDER_TLS_KEY=/etc/ladder-agent/tls/server.key
