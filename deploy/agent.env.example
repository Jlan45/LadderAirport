# /etc/labber-agent/agent.env
# Shared with Panel node token / default agent token

LABBER_LISTEN=0.0.0.0:50051
LABBER_TOKEN=change-me-to-a-long-secret
LABBER_DATA_DIR=/var/lib/labber-agent

# Optional TLS:
# LABBER_TLS_CERT=/etc/labber-agent/tls/agent.crt
# LABBER_TLS_KEY=/etc/labber-agent/tls/agent.key
