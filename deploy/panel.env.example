# /etc/ladder-panel/panel.env
LADDER_LISTEN=:8080
LADDER_DB=/var/lib/ladder-panel/panel.db
# 固定后重启不掉登录态；install-panel.sh 未设置时会自动生成
LADDER_SESSION_SECRET=change-me-to-a-long-random-secret

# 启动时对已登记节点自动下发配置并 Start
LADDER_BOOTSTRAP=true
LADDER_BOOTSTRAP_TIMEOUT=3m
LADDER_BOOTSTRAP_RETRY=true
LADDER_BOOTSTRAP_RETRY_INTERVAL=30s
